# Dossier de stockage persistant des sessions WhatsApp.
# En local : laisse vide (utilise ./data). Sur Render/Katabump : /data
DATA_DIR=

# API de l'IA (ChapeauNoir)
API_URL=https://bj-tricks-ai.vercel.app/chat

# Lien d'invitation du groupe (optionnel)
GROUP_LINK=https://chat.whatsapp.com/xxx

# Delai avant reponse de l'IA (ms)
AI_RESPONSE_DELAY=2900

# Anti-spam
SPAM_LIMIT=5
SPAM_WINDOW=10000
